<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipChildren="false">

    <!-- Container for the panel -->
    <LinearLayout
        android:id="@+id/panelContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="12dp"
        android:clipChildren="false"
        android:gravity="center_horizontal"
        android:orientation="vertical">
<!-- Main Sidebar Pill -->
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/panelCard"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_panel"
    android:elevation="32dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp">

    <!-- Rich Vertical Handle -->
    <View
        android:id="@+id/panelHandle"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/bg_close_btn"
        android:backgroundTint="#40FFFFFF"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Scrollable app list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPanelApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="4dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/toolsContainer" />

    <!-- Tools Section (GridLayout mirrors panelColumns) -->
    <android.widget.GridLayout
        android:id="@+id/toolsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:useDefaultMargins="false"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/rvPanelApps"
        app:layout_constraintBottom_toTopOf="@id/layoutSysInfo">

        <!-- Divider -->
        <View
            android:id="@+id/toolsDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_columnWeight="1"
            android:layout_marginBottom="8dp" />

        <!-- Power Menu -->
        <LinearLayout
            android:id="@+id/layoutPowerTools"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">
            <Button
                android:id="@+id/btnReboot"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:text="⛔"
                android:textColor="#D9FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Volume -->
        <LinearLayout
            android:id="@+id/layoutVolumeTools"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">
            <Button
                android:id="@+id/btnVolumeDrag"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:text="🎵"
                android:textColor="#D9FFFFFF"
                android:textSize="16sp"
                android:contentDescription="Drag to adjust volume (up increases, down decreases)" />
        </LinearLayout>

        <!-- Brightness -->
        <LinearLayout
            android:id="@+id/layoutBrightnessTools"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">
            <Button
                android:id="@+id/btnBrightnessDrag"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:text="✨"
                android:textColor="#D9FFFFFF"
                android:textSize="16sp"
                android:contentDescription="Drag to adjust brightness (up increases, down decreases)" />
        </LinearLayout>

        <!-- Screenshot -->
        <LinearLayout
            android:id="@+id/layoutScreenshotTools"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">
            <Button
                android:id="@+id/btnScreenshot"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:text="📱"
                android:textColor="#D9FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Black Screen -->
        <LinearLayout
            android:id="@+id/layoutBlackScreenTools"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">
            <Button
                android:id="@+id/btnBlackScreen"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:text="⬛"
                android:textColor="#D9FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Lock Screen -->
        <LinearLayout
            android:id="@+id/layoutLockScreenTools"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">
            <Button
                android:id="@+id/btnLockScreen"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:text="📵"
                android:textColor="#D9FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

    </android.widget.GridLayout>

        <!-- System Info: standalone section below tools grid, always centered. -->
        <LinearLayout
            android:id="@+id/layoutSysInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/toolsContainer"
            app:layout_constraintBottom_toTopOf="@id/btnClose"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/tvRamUsage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RAM: --"
                android:textColor="#B3FFFFFF"
                android:textSize="10sp" />
            <TextView
                android:id="@+id/tvBatTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAT: --"
                android:textColor="#B3FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>


            <!-- Back button for folder navigation -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:contentDescription="Back"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_arrow_back"
                android:tint="#D9FFFFFF"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutSysInfo"
            app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Chevron at bottom of pill (now handles picker toggle) -->
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_close_btn"
                android:backgroundTint="#1AFFFFFF"
                android:contentDescription="Toggle Picker"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                android:tint="#D9FFFFFF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutSysInfo" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

</RelativeLayout>
