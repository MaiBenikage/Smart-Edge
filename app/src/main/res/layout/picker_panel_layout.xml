<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pickerPanelCard"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/bg_picker_panel"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:elevation="24dp"
    android:orientation="vertical"
    android:padding="16dp">
    <!-- Modern Header Dashboard -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Modern Search Capsule -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1AFFFFFF"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#80FFFFFF" />

            <EditText
                android:id="@+id/etPickerSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="Search Smart Edge..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Settings Cog - Pill Shape -->
        <ImageButton
            android:id="@+id/btnPickerClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1AFFFFFF"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_settings"
            android:tint="#B3FFFFFF" />
    </LinearLayout>

    <!-- 4-tab Selector: APPS / ACTIVITIES / SHORTCUTS / URLS -->
    <LinearLayout
        android:id="@+id/layoutTabRow"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_close_btn"
        android:backgroundTint="#0DFFFFFF"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="2dp">

        <TextView
            android:id="@+id/tabApps"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1AFFFFFF"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:text="APPS"
            android:textColor="#FFFFFF"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tabActivities"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:text="ACTS"
            android:textColor="#80FFFFFF"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tabShortcuts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:text="SHTS"
            android:textColor="#80FFFFFF"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tabCustom"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:text="URLS"
            android:textColor="#80FFFFFF"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Header Stats/Actions Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPickerHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="All Apps"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:alpha="0.8" />

        <!-- Edit/Done Toggle Chip (apps/activities/shortcuts) -->
        <!-- OR + Add Chip (intents/urls) -->
        <TextView
            android:id="@+id/btnPickerEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_close_btn"
            android:backgroundTint="#1AFFFFFF"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="EDIT"
            android:textColor="#4A9EFF"
            android:textSize="11sp"
            android:textAllCaps="true" />
    </LinearLayout>

    <!-- Notifications Section (Horizontal) -->
    <LinearLayout
        android:id="@+id/layoutPickerNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/btnToggleNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active Notifications"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <ImageView
                android:id="@+id/ivNotificationsChevron"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_chevron_right"
                android:rotation="90"
                android:tint="#80FFFFFF" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPickerNotifications"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <View
            android:id="@+id/divNotifications"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Grid with fixed max height -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPickerGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="vertical" />

</LinearLayout>
