<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:animateLayoutChanges="true">

        <!-- STATUS SECTION -->
        <LinearLayout
            android:id="@+id/statusContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorError"
                app:strokeWidth="0dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="System automation is currently inactive"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:alpha="0.8" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable high-performance gestures that bypass the need for traditional Accessibility Services."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:lineHeight="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="?attr/colorOutlineVariant"
            android:alpha="0.4" />

        <!-- ADB SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Manual Setup (ADB)"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyAdb"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Copy Command"
                android:textSize="12sp"
                app:icon="@drawable/ic_copy"
                app:iconSize="14dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant">
            <TextView
                android:id="@+id/tvAdbCommand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="adb shell pm grant..."
                android:textColor="?attr/colorOnSurface"
                android:textSize="10sp"
                android:typeface="monospace"
                android:alpha="0.7" />
        </com.google.android.material.card.MaterialCardView>

        <!-- AUTOMATED SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="One-Tap Methods"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <!-- Shizuku Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shizuku"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADB-based wireless automation"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRevokeShizuku"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Revoke"
                android:textColor="?attr/colorError"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrantShizuku"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Grant"
                android:textSize="12sp"
                app:cornerRadius="19dp"
                android:paddingHorizontal="16dp"
                app:strokeColor="?attr/colorPrimary"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>

        <!-- Root Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Root Access"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Direct system-level integration"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRevokeRoot"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Revoke"
                android:textColor="?attr/colorError"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGrantRoot"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Grant"
                android:textSize="12sp"
                app:cornerRadius="19dp"
                android:paddingHorizontal="16dp"
                app:strokeColor="?attr/colorPrimary"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>