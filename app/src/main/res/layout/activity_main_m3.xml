<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/app_screen_padding">

            <!-- HEADER HERO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="40dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_hero_subtitle"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:alpha="0.7"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- SERVICE STATUS CARD -->
            <com.google.android.material.card.MaterialCardView
                style="@style/App_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/main_service_title"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="4dp">
                                
                                <ImageView
                                    android:id="@+id/statusDot"
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:src="@android:drawable/presence_online"
                                    android:layout_marginEnd="8dp"
                                    app:tint="?attr/colorOnSurfaceVariant" />

                                <TextView
                                    android:id="@+id/tvStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/main_service_stopped"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartStop"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:layout_alignParentEnd="true"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            app:icon="@drawable/ic_power"
                            app:iconSize="36dp"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:cornerRadius="36dp"
                            app:backgroundTint="?attr/colorPrimary"
                            android:textColor="?attr/colorOnPrimary"
                            app:elevation="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartStopClassic"
                            style="@style/App_Button_Continue"
                            android:layout_width="wrap_content"
                            android:layout_height="54dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="@string/start_panel"
                            app:backgroundTint="?attr/colorPrimary"
                            android:textColor="?attr/colorOnPrimary"
                            android:visibility="gone" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginVertical="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTogglePanel"
                        style="@style/App_Button_Continue"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="@string/main_test_sidebar"
                        android:textSize="16sp"
                        app:icon="@drawable/ic_test_directions"
                        app:iconGravity="textStart"
                        app:iconTint="?attr/colorOnPrimary"
                        app:backgroundTint="?attr/colorPrimary"
                        android:textColor="?attr/colorOnPrimary"
                        app:cornerRadius="24dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BATTERY OPTIMIZATION ALERT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBatteryOptimization"
                style="@style/App_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="1dp"
                app:strokeColor="#2ECC71"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/alert_battery_title"
                        android:textColor="#2ECC71"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/alert_battery_desc"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnIgnoreBattery"
                        style="@style/App_Button_Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="#2ECC71"
                        android:text="@string/alert_battery_btn"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FREEFORM OPTIMIZATION ALERT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFreeformOptimization"
                style="@style/App_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorSecondary"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/alert_freeform_title"
                        android:textColor="?attr/colorSecondary"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/alert_freeform_desc"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFixFreeform"
                        style="@style/App_Button_Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="?attr/colorSecondary"
                        android:text="@string/alert_freeform_btn"
                        android:textColor="?attr/colorOnSecondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PERMISSION ALERT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPermission"
                style="@style/App_Card"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/alert_permission_title"
                        android:textColor="?attr/colorError"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/alert_permission_desc"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantPermission"
                        style="@style/App_Button_Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="?attr/colorError"
                        android:text="@string/alert_permission_btn"
                        android:textColor="?attr/colorOnError" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ACTIVITY LOGS BUTTON -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnShowLogs"
                style="@style/App_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="@string/main_logs_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SETTINGS QUICK ACTION -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSettings"
                style="@style/App_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings_advanced"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="@string/main_settings_btn"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHowToUse"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/main_how_to_use"
                android:layout_marginBottom="12dp"
                app:icon="@android:drawable/ic_menu_help"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnSurfaceVariant"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:strokeColor="?attr/colorOutlineVariant"
                app:cornerRadius="20dp" />

            <LinearLayout
                android:id="@+id/layoutTutorialContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    style="@style/App_Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp">

                    <LinearLayout
                        style="@style/App_CardContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="320dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurfaceContainerLow">
                            
                            <ImageView
                                android:id="@+id/ivTutorialAnim"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitXY" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/main_tutorial_desc"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSideloadNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/main_sideload_note"
                android:textColor="?attr/colorOutline"
                android:textSize="11sp"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
