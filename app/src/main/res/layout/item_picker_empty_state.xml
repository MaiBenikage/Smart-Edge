<?xml version="1.0" encoding="utf-8"?>
<!--
    Empty-state placeholder used by the picker tabs when there's no data to show.
    Shown when:
      - APPS tab: no installed apps
      - ACTIVITIES tab: no exported activities
      - SHORTCUTS tab: no app shortcuts visible (or no shortcut-host permission)
      - URLS tab: no user-added custom items
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingVertical="24dp">

    <TextView
        android:id="@+id/tvEmptyStateMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.6"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="No items"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

</LinearLayout>
